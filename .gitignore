# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# SQLite (local Prisma dev DB; never publish)
*.db
*.db-journal

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client (created by `prisma generate` / postinstall)
/generated

# Local JSON dataset exports (ingest reads these; do not commit user data)
/prompts/**
!/prompts/.gitkeep
/Prompts/**
!/Prompts/.gitkeep

# Entire `projects/` tree — local special-project exports, scripts, and paths (not for public clone).
/projects/**
!/projects/.gitkeep

# Repo-root `users/` — local Fleet user exports and tokens (not `app/users` routes).
/users/**
!/users/.gitkeep
